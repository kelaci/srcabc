---
import SeoHead from "../components/SeoHead.astro";
import { siteMeta } from "../config/site";
import stylesUrl from "../styles/global.css?url";
import type { FaqItem, StructuredData } from "../types/site";
import { buildDefaultStructuredData } from "../utils/structuredData";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  structuredData?: StructuredData[];
  faqItems?: FaqItem[];
  breadcrumbItems?: { name: string; url: string }[];
  canonical?: string;
  image?: string;
}

const {
  title = siteMeta.defaultPageTitle,
  description = siteMeta.description,
  noindex = false,
  structuredData,
  faqItems,
  breadcrumbItems,
  canonical,
  image,
} = Astro.props;

const resolvedStructuredData = noindex
  ? []
  : structuredData ?? buildDefaultStructuredData({
      description,
      faqItems,
      breadcrumbItems: breadcrumbItems ?? [
        { name: "Home", url: siteMeta.url },
      ],
    });
---

<!doctype html>
<html lang="en">
  <head>
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <SeoHead
      title={title}
      description={description}
      pathname={Astro.url.pathname}
      noindex={noindex}
      canonical={canonical}
      image={image}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=DM+Serif+Display&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    {
      resolvedStructuredData.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema).replace(/</g, '\\u003c')} is:inline />
      ))
    }
    <link rel="stylesheet" href={stylesUrl} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div id="top"></div>
    <slot />
    <script src="/scripts/site.client.js" type="module" is:inline></script>
  </body>
</html>
