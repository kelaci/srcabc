---
import type { FooterContent } from "../types/site";

interface Props {
  content: FooterContent;
}

const { content } = Astro.props;
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-col">
      <a class="brand" href="#top">src<span>abc</span>.com</a>
      <p style="max-width: 36rem; margin: 16px 0 0;">{content.summary}</p>
      {content.note && <div class="footer-note">{content.note}</div>}
    </div>

    <div class="footer-col">
      <h4>Direct links</h4>
      <ul class="footer-links">
        {
          content.links.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))
        }
        <li><a href={content.contactAction.href}>{content.contactAction.label}</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Public references</h4>
      <ul class="footer-links">
        {
          content.references.map((item) => (
            <li><a href={item.href} rel="noreferrer" target="_blank">{item.label}</a></li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>
