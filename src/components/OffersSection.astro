---
import SectionIntro from "./common/SectionIntro.astro";
import type { OffersSectionContent } from "../types/site";

interface Props {
  content: OffersSectionContent;
}

const { content } = Astro.props;
---

<section id="offers">
  <div class="container">
    <SectionIntro
      eyebrow={content.eyebrow}
      title={content.title}
      description={content.description}
    />

    <div class="offer-tabs reveal" aria-label="Offer categories" role="group">
      {
        content.tabs.map((tab, index) => (
          <button
            aria-pressed={index === 0 ? "true" : "false"}
            class:list={["tab-btn", index === 0 && "active"]}
            data-offer-tab={tab.id}
            type="button"
          >
            {tab.label}
          </button>
        ))
      }
    </div>

    <div class="offers-grid">
      {
        content.items.map((offer) => (
          <article
            aria-hidden="false"
            class:list={[
              "offer-card",
              "is-visible",
              "reveal",
              offer.emphasis && "is-emphasis",
            ]}
            data-kind={offer.kinds.join(" ")}
            data-offer-card
          >
            <div class="offer-meta">
              {
                offer.meta.map((item) => (
                  <span class="tag">{item}</span>
                ))
              }
            </div>
            <h3>{offer.title}</h3>
            <p>{offer.description}</p>
            <ul class="bullet-list">
              {
                offer.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
