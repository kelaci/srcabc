---
import { offerTabs, offers } from "../data/site";
---

<section id="offers">
  <div class="container">
    <div class="section-head reveal">
      <div>
        <span class="eyebrow"><span class="dot"></span> What you can buy</span>
        <h2>Productized offers instead of vague consulting.</h2>
      </div>
      <p>
        The site should not sell smartness. It should sell a sharper decision, a faster validation loop, and a more persuasive output. These four offers give the business a clean ladder from first engagement to long-term advisory.
      </p>
    </div>

    <div class="offer-tabs reveal" role="tablist" aria-label="Offer categories">
      {
        offerTabs.map((tab, index) => (
          <button
            aria-selected={index === 0 ? "true" : "false"}
            class:list={["tab-btn", index === 0 && "active"]}
            data-offer-tab={tab.id}
            role="tab"
            type="button"
          >
            {tab.label}
          </button>
        ))
      }
    </div>

    <div class="offers-grid">
      {
        offers.map((offer) => (
          <article
            aria-hidden="false"
            class:list={[
              "offer-card",
              "is-visible",
              "reveal",
              offer.emphasis && "is-emphasis",
            ]}
            data-kind={offer.kinds.join(" ")}
            data-offer-card
          >
            <div class="offer-meta">
              {
                offer.meta.map((item) => (
                  <span class="tag">{item}</span>
                ))
              }
            </div>
            <h3>{offer.title}</h3>
            <p>{offer.description}</p>
            <ul class="bullet-list">
              {
                offer.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
