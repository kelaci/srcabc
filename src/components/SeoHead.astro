---
import { SEO } from "astro-seo";
import { siteMeta } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = siteMeta.defaultPageTitle,
  description = siteMeta.description,
  pathname = Astro.url.pathname,
  image = siteMeta.ogImage,
  noindex = false,
} = Astro.props;

const canonical = new URL(pathname, Astro.site ?? siteMeta.url).href;
const imageUrl = new URL(image, Astro.site ?? siteMeta.url).href;
---

<SEO
  charset="UTF-8"
  canonical={canonical}
  description={description}
  noindex={noindex}
  openGraph={{
    basic: {
      title: `${title} | ${siteMeta.siteName}`,
      type: "website",
      image: imageUrl,
      url: canonical,
    },
    optional: {
      description,
      locale: siteMeta.locale,
      siteName: siteMeta.siteName,
    },
    image: {
      alt: siteMeta.ogImageAlt,
      width: 1200,
      height: 630,
      type: "image/png",
    },
  }}
  robotsExtras="max-snippet:-1, max-image-preview:large, max-video-preview:-1"
  title={title}
  titleDefault={siteMeta.defaultPageTitle}
  titleTemplate={siteMeta.titleTemplate}
  twitter={{
    card: "summary_large_image",
    title: `${title} | ${siteMeta.siteName}`,
    description,
    image: imageUrl,
    imageAlt: siteMeta.ogImageAlt,
  }}
  extend={{
    link: [
      { rel: "manifest", href: "/site.webmanifest" },
      { rel: "icon", href: "/favicon.svg", type: "image/svg+xml" },
      { rel: "icon", href: "/favicon.ico", sizes: "any" },
      { rel: "icon", href: "/favicon-32x32.png", sizes: "32x32", type: "image/png" },
      { rel: "icon", href: "/favicon-16x16.png", sizes: "16x16", type: "image/png" },
      { rel: "apple-touch-icon", href: "/apple-touch-icon.png", sizes: "180x180" },
    ],
    meta: [
      { name: "theme-color", content: "#07111f" },
      { name: "application-name", content: siteMeta.siteName },
      { name: "apple-mobile-web-app-title", content: siteMeta.siteName },
      { name: "keywords", content: siteMeta.keywords.join(", ") },
      { property: "og:image:secure_url", content: imageUrl },
    ],
  }}
/>
