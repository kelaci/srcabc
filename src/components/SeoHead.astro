---
import { siteMeta } from "../config/site";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
  noindex?: boolean;
  articlePublishedTime?: string;
  articleAuthor?: string;
  canonical?: string;
}

const {
  title = siteMeta.defaultPageTitle,
  description = siteMeta.description,
  pathname = Astro.url.pathname,
  image = siteMeta.ogImage,
  noindex = false,
  articlePublishedTime,
  articleAuthor,
  canonical: customCanonical,
} = Astro.props;

const canonical = customCanonical || new URL(pathname, Astro.site ?? siteMeta.url).href;
const imageUrl = new URL(image, Astro.site ?? siteMeta.url).href;
const pageTitle = siteMeta.titleTemplate.replace("%s", title);
const robotsContent = [
  noindex ? "noindex" : "index",
  "follow",
  "max-snippet:-1",
  "max-image-preview:large",
  "max-video-preview:-1",
].join(", ");
const isHomePage = pathname === "/" || pathname === "";

// Generate alternate locale URLs by replacing the base domain
const alternateLocaleLinks = siteMeta.alternateLocales?.map((alt) => {
  const altUrl = new URL(pathname, alt.href).href;
  return { href: altUrl, hreflang: alt.hreflang };
}) || [];
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{pageTitle}</title>
<link rel="canonical" href={canonical} />
<meta name="description" content={description} />
<meta name="robots" content={robotsContent} />
<meta name="author" content={siteMeta.siteName} />
<meta name="generator" content="Astro" />
{isHomePage && <meta name="googlebot" content="index, follow" />}
<meta name="theme-color" content="#07111f" />
<meta name="application-name" content={siteMeta.siteName} />
<meta name="apple-mobile-web-app-title" content={siteMeta.siteName} />
<meta name="keywords" content={siteMeta.keywords.join(", ")} />

{alternateLocaleLinks.map((link) => (
  <link rel="alternate" href={link.href} hreflang={link.hreflang} />
))}
<link rel="alternate" href={canonical} hreflang="en" />
<link rel="alternate" href={canonical} hreflang="x-default" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
<link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />

<meta property="og:type" content={isHomePage ? "website" : "article"} />
{articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
{articleAuthor && <meta property="article:author" content={articleAuthor} />}
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={siteMeta.locale} />
<meta property="og:site_name" content={siteMeta.siteName} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:secure_url" content={imageUrl} />
<meta property="og:image:alt" content={siteMeta.ogImageAlt} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@srcabc" />
<meta name="twitter:creator" content="@srcabc" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={siteMeta.ogImageAlt} />

<meta name="format-detection" content="telephone=no" />