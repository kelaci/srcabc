---
import SectionIntro from "./common/SectionIntro.astro";
import type { ProcessSectionContent } from "../types/site";

interface Props {
  content: ProcessSectionContent;
}

const { content } = Astro.props;
---

<section id="process">
  <div class="container">
    <SectionIntro
      eyebrow={content.eyebrow}
      title={content.title}
      description={content.description}
    />

    <div class="process-grid">
      {
        content.steps.map((step) => (
          <article class="process-card reveal">
            <div class="process-index">{step.index}</div>
            <div class="micro-label">{step.label}</div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
            <ul class="bullet-list">
              {
                step.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
