---
import SectionIntro from "./common/SectionIntro.astro";
import type { FitSectionContent } from "../types/site";

interface Props {
  content: FitSectionContent;
}

const { content } = Astro.props;
---

<section id="fit">
  <div class="container">
    <SectionIntro
      eyebrow={content.eyebrow}
      title={content.title}
      description={content.description}
    />

    <div class="fit-grid">
      {
        content.cards.map((card) => (
          <article class="fit-card reveal">
            <div class="micro-label">{card.label}</div>
            <h3>{card.title}</h3>
            <ul class="bullet-list">
              {
                card.bullets.map((bullet) => (
                  <li>{bullet}</li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
