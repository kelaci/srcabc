---
import type { HeroContent } from "../types/site";

interface Props {
  content: HeroContent;
}

const { content } = Astro.props;
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy reveal">
      <span class="eyebrow"><span class="dot"></span> {content.eyebrow}</span>
      <h1>{content.titleLead} <span class="accent">{content.titleAccent}</span></h1>
      <p class="lead">{content.intro}</p>

      <div class="hero-actions">
        <a class="button" href={content.primaryAction.href}>{content.primaryAction.label}</a>
        <a class="button-ghost" href={content.secondaryAction.href}>{content.secondaryAction.label}</a>
      </div>

      <div class="signal-strip">
        <strong>{content.signalLabel}</strong>
        <div class="signal-list">
          {
            content.signalItems.map((item) => (
              <span class="pill">{item}</span>
            ))
          }
        </div>
      </div>

      <div class="hero-proof">
        {
          content.metrics.map((metric) => (
            <div class="metric">
              <div class="label">{metric.label}</div>
              <strong>{metric.title}</strong>
              <p>{metric.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <aside class="hero-panel reveal">
      <div class="hero-panel-top">
        {
          content.statusChips.map((status, index) => (
            <span class="status-chip">
              {index === 0 && <span class="mini-dot"></span>}
              {status}
            </span>
          ))
        }
      </div>

      <div>
        <div class="micro-label">{content.panelLabel}</div>
        <h2 class="hero-panel-title">{content.panelTitle}</h2>
        {content.panelKicker && <p class="hero-panel-kicker">{content.panelKicker}</p>}
        <p class="hero-panel-copy">{content.panelCopy}</p>
      </div>

      <div class="hero-stack">
        {
          content.coreCards.map((card) => (
            <article class="stack-card">
              <div class="stack-icon">{card.icon}</div>
              <strong>{card.title}</strong>
              <p>{card.description}</p>
            </article>
          ))
        }
      </div>

      <div class="panel-note">
        <strong>Best fit:</strong> {content.panelNote}
      </div>
    </aside>
  </div>
</section>
