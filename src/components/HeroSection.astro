---
import { coreCards, heroMetrics } from "../data/site";
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy reveal">
      <span class="eyebrow"><span class="dot"></span> Applied research systems studio</span>
      <h1>Software ideas that are expensive to get <span class="accent">wrong.</span></h1>
      <p class="lead">
        SRCABC helps founders and engineering teams validate AI, interactive, and systems-level product bets through benchmark-driven research, working prototypes, and build-ready architecture.
      </p>

      <div class="hero-actions">
        <a class="button" href="#contact">Discuss your project</a>
        <a class="button-ghost" href="#proof">See public work</a>
      </div>

      <div class="signal-strip">
        <strong>What you buy:</strong>
        <div class="signal-list">
          <span class="pill">Research sprint</span>
          <span class="pill">Working prototype</span>
          <span class="pill">System blueprint</span>
          <span class="pill">Founder / CTO advisory</span>
        </div>
      </div>

      <div class="hero-proof">
        {
          heroMetrics.map((metric) => (
            <div class="metric">
              <div class="label">{metric.label}</div>
              <strong>{metric.title}</strong>
              <p>{metric.description}</p>
            </div>
          ))
        }
      </div>
    </div>

    <aside class="hero-panel reveal">
      <div class="hero-panel-top">
        <span class="status-chip"><span class="mini-dot"></span> Founder-led</span>
        <span class="status-chip">High-signal engagements</span>
      </div>

      <div>
        <div class="micro-label">Core model</div>
        <h2 style="margin:10px 0 12px; font-size: clamp(2rem, 4vw, 3.2rem); line-height: 0.98; max-width: 11ch;">
          Applied research first. Beautiful execution second. Commodity work never.
        </h2>
        <p style="margin:0; color: var(--muted); max-width: 33rem;">
          This is not a generic dev shop and not a pure think tank. SRCABC is strongest when the project needs sharp technical judgment, a convincing demo, and a final recommendation the client can actually build on.
        </p>
      </div>

      <div class="hero-stack">
        {
          coreCards.map((card) => (
            <article class="stack-card">
              <div class="stack-icon">{card.icon}</div>
              <strong>{card.title}</strong>
              <p>{card.description}</p>
            </article>
          ))
        }
      </div>

      <div class="panel-note">
        <strong>Best fit:</strong> early product bets, AI features with unclear UX or architecture, premium technical showcases, internal tools that need strategic clarity, and R&amp;D-heavy concepts that must become legible to buyers or stakeholders.
      </div>
    </aside>
  </div>
</section>
