---
import SectionIntro from "./common/SectionIntro.astro";
import type { ProofSectionContent } from "../types/site";

interface Props {
  content: ProofSectionContent;
}

const { content } = Astro.props;
---

<section id="proof">
  <div class="container">
    <SectionIntro
      eyebrow={content.eyebrow}
      title={content.title}
      description={content.description}
    />

    <div class="proof-grid">
      {
        content.items.map((item) => (
          <article class="proof-card reveal">
            <div class="offer-meta">
              {
                item.meta.map((meta) => (
                  <span class="tag">{meta}</span>
                ))
              }
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <div class="proof-links">
              <a class="button-line" href={item.link.href} rel="noreferrer" target="_blank">
                {item.link.label}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
