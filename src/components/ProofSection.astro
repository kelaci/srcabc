---
import { proofItems } from "../data/site";
---

<section id="proof">
  <div class="container">
    <div class="section-head reveal">
      <div>
        <span class="eyebrow"><span class="dot"></span> Public proof</span>
        <h2>Show the work. Then ask for trust.</h2>
      </div>
      <p>
        A new studio should not lead with inflated claims. It should lead with visible evidence. These public references support the long-term positioning far better than generic agency language ever could.
      </p>
    </div>

    <div class="proof-grid">
      {
        proofItems.map((item) => (
          <article class="proof-card reveal">
            <div class="offer-meta">
              {
                item.meta.map((meta) => (
                  <span class="tag">{meta}</span>
                ))
              }
            </div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <div class="proof-links">
              <a class="button-line" href={item.linkHref} rel="noreferrer" target="_blank">
                {item.linkLabel}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
