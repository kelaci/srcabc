---
import type { ContactSectionContent } from "../types/site";

interface Props {
  content: ContactSectionContent;
}

const { content } = Astro.props;
---

<section id="contact">
  <div class="container">
    <div class="cta-shell reveal">
      <div>
        <span class="eyebrow"><span class="dot"></span> {content.eyebrow}</span>
        <h2>{content.title}</h2>
        <p>{content.description}</p>
        <div class="contact-meta">
          {
            content.pills.map((pill) => (
              <span class="pill">{pill}</span>
            ))
          }
        </div>
      </div>

      <div class="cta-actions">
        <a class="button" href={content.primaryAction.href}>
          {content.primaryAction.label}
        </a>
        <button
          aria-describedby="copy-email-status"
          aria-label={`Copy email address ${content.primaryAction.label}`}
          class="button-ghost"
          data-copy-email
          data-copy-success={content.copyAnnouncement}
          data-email={content.primaryAction.label}
          type="button"
        >
          {content.copyButtonLabel}
        </button>
        <p class="sr-only" id="copy-email-status" aria-live="polite" role="status" data-copy-status></p>
      </div>
    </div>
  </div>
</section>
