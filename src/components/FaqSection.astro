---
import SectionIntro from "./common/SectionIntro.astro";
import type { FaqSectionContent } from "../types/site";

interface Props {
  content: FaqSectionContent;
}

const { content } = Astro.props;

const toParagraphs = (answer: string | string[]) =>
  Array.isArray(answer) ? answer : [answer];
---

<section id="faq">
  <div class="container">
    <SectionIntro
      eyebrow={content.eyebrow}
      title={content.title}
      description={content.description}
    />

    <div class="faq-grid">
      {
        content.items.map((item, index) => {
          const answerId = `faq-answer-${index}`;
          const buttonId = `faq-toggle-${index}`;
          const isOpen = index === 0;
          return (
            <article class:list={["faq-item", "reveal", isOpen && "open"]} data-faq-item>
              <button
                id={buttonId}
                aria-controls={answerId}
                aria-expanded={isOpen ? "true" : "false"}
                class="faq-toggle"
                data-faq-toggle
                type="button"
              >
                <span class="faq-copy">
                  <span class="micro-label">{item.label}</span>
                  <span class="faq-question">{item.question}</span>
                </span>
                <span aria-hidden="true">+</span>
              </button>
              <div
                aria-labelledby={buttonId}
                class="faq-answer"
                data-faq-answer
                id={answerId}
                role="region"
              >
                <div class="faq-answer-inner">
                  {toParagraphs(item.answer).map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
