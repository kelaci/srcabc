---
import { faqItems } from "../data/site";
---

<section id="faq">
  <div class="container">
    <div class="section-head reveal">
      <div>
        <span class="eyebrow"><span class="dot"></span> FAQ</span>
        <h2>Questions a serious buyer will actually ask.</h2>
      </div>
      <p>
        This section helps the site behave more like a sales asset and less like a moodboard.
      </p>
    </div>

    <div class="faq-grid">
      {
        faqItems.map((item, index) => {
          const answerId = `faq-answer-${index}`;
          const buttonId = `faq-toggle-${index}`;
          const isOpen = index === 0;
          return (
            <article class:list={["faq-item", "reveal", isOpen && "open"]} data-faq-item>
              <button
                id={buttonId}
                aria-controls={answerId}
                aria-expanded={isOpen ? "true" : "false"}
                class="faq-toggle"
                data-faq-toggle
                type="button"
              >
                <span class="faq-copy">
                  <span class="micro-label">{item.label}</span>
                  <span class="faq-question">{item.question}</span>
                </span>
                <span aria-hidden="true">+</span>
              </button>
              <div
                aria-labelledby={buttonId}
                class="faq-answer"
                data-faq-answer
                id={answerId}
                role="region"
              >
                <div class="faq-answer-inner">{item.answer}</div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
